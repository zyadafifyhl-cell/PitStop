# REQUIRED: OpenAI API Key for AI Assistant
# Get your API key from: https://platform.openai.com/api-keys
# This powers the bilingual car problem diagnosis chatbot
EXPO_PUBLIC_OPENAI_API_KEY=your_openai_api_key_here

# OPTIONAL: Supabase Configuration (for cloud sync & authentication)
# Get these from your Supabase project settings
EXPO_PUBLIC_SUPABASE_URL=your_supabase_project_url_here
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_publishable_key_here
